{
  "name": "NutritionLog",
  "type": "object",
  "properties": {
    "date": {
      "type": "string",
      "format": "date"
    },
    "meal_type": {
      "type": "string",
      "enum": [
        "breakfast",
        "lunch",
        "dinner",
        "snack"
      ]
    },
    "food_name": {
      "type": "string"
    },
    "portion_size": {
      "type": "string"
    },
    "calories": {
      "type": "number"
    },
    "protein_g": {
      "type": "number"
    },
    "carbs_g": {
      "type": "number"
    },
    "fat_g": {
      "type": "number"
    },
    "fiber_g": {
      "type": "number"
    },
    "sodium_mg": {
      "type": "number"
    },
    "sugar_g": {
      "type": "number"
    },
    "notes": {
      "type": "string"
    },
    "followed_plan": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "date",
    "meal_type",
    "food_name"
  ]
}